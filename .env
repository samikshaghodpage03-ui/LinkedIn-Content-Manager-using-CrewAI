# LinkedIn Content Manager - Environment Configuration
# Copy this file to .env and fill in your actual API keys

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
# Model used: gpt-4 or gpt-4o (recommended for best results)
OPENAI_API_KEY="Your_OpenAI_API_Key_Here"

# Serper Dev Tool API Configuration
# Get your API key from: https://serper.dev/
# Used for web search to research trending topics
SERPER_API_KEY="Your_Serper_API_Key_Here"

# Optional: LLM Model Selection
# Options: gpt-4, gpt-4o, gpt-3.5-turbo
# gpt-4o is recommended for best quality
# LLM_MODEL=gpt-4o

# Optional: Logging Level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
